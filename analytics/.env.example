# Supabase project the analytics service reads from and writes flags into.
SUPABASE_URL=https://heiimxqyxthxtnxqozap.supabase.co
SUPABASE_SERVICE_KEY=replace-with-service-role-key

# DEMO mode: when true, detectors run on synthetic data so the Anomaly Center is
# populated without months of history. Set false once real history exists.
ANALYTICS_DEMO_MODE=true

# How often the scheduler runs all detectors (seconds).
SCAN_INTERVAL_SECONDS=600

# Decision values (doc §8) — tune per Suntek.
MIN_MARGIN_PCT=10
OFFSPEC_TOLERANCE_PCT=3
RECON_NOISE_PCT=4
THROUGHPUT_SIGMA=2.5

# Optional alerting (Critical flags). Leave blank to disable.
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
ALERT_EMAIL_WEBHOOK=
